###  https://www.michaeldebellis.com/streamforge/Ads_Revenue_Reconciliation_Notes_Nov_2025
sf:Ads_Revenue_Reconciliation_Notes_Nov_2025 rdf:type owl:NamedIndividual ,
                                                      docs:Document ;
                                             docs:uses_data_product sf:SF_Ads_Performance_Data_Product ;
                                             docs:uses_dataset sf:SF_Ads_Performance_Dataset ;
                                             dctm:created "2025-11-20"^^xsd:date ;
                                             dctm:creator "Monetization"@en ;
                                             dctm:publisher "StreamForge Finance Engineering"@en ;
                                             dctm:title "Ads Revenue Reconciliation Notes (Nov 2025)"@en ;
                                             rdfs:label "Ads Revenue Reconciliation Notes Nov 2025"@en ;
                                             dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 has creator Monetization."@en ,
                                                               "Ads Revenue Reconciliation Notes Nov 2025 has publisher StreamForge Finance Engineering."@en ,
                                                               "Ads Revenue Reconciliation Notes Nov 2025 is an instance of Document."@en ,
                                                               "Ads Revenue Reconciliation Notes Nov 2025 uses data product SF Ads Performance Data Product."@en ,
                                                               "Ads Revenue Reconciliation Notes Nov 2025 uses dataset SF Ads Performance Dataset."@en .


###  https://www.michaeldebellis.com/streamforge/Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_01
sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_01 rdf:type owl:NamedIndividual ,
                                                               docs:Document_Chunk ;
                                                      docs:chunk_index 1 ;
                                                      docs:chunk_text "This note documents how daily ad revenue is reconciled between delivery logs and finance reporting. The goal is consistent numbers across dashboards and the general ledger."@en ;
                                                      docs:chunk_title "Context"@en ;
                                                      rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 01"@en ;
                                                      dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 01 has title Context."@en .


###  https://www.michaeldebellis.com/streamforge/Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_02
sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_02 rdf:type owl:NamedIndividual ,
                                                               docs:Document_Chunk ;
                                                      docs:chunk_index 2 ;
                                                      docs:chunk_text "We used the StreamForge Ads Performance data product. It provides daily aggregates by video and channel, sourced from ad server logs and summarized into BigQuery tables."@en ;
                                                      docs:chunk_title "Data sources"@en ;
                                                      rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 02"@en ;
                                                      dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 02 has title Data sources."@en .


###  https://www.michaeldebellis.com/streamforge/Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_03
sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_03 rdf:type owl:NamedIndividual ,
                                                               docs:Document_Chunk ;
                                                      docs:chunk_index 3 ;
                                                      docs:chunk_text "Late-arriving events and currency conversion updates can shift revenue totals. A 'finalized_date' convention is recommended so stakeholders know when a day’s revenue is stable."@en ;
                                                      docs:chunk_title "Known pitfalls"@en ;
                                                      rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 03"@en ;
                                                      dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 03 has title Known pitfalls."@en .


###  https://www.michaeldebellis.com/streamforge/Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_04
sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_04 rdf:type owl:NamedIndividual ,
                                                               docs:Document_Chunk ;
                                                      docs:chunk_index 4 ;
                                                      docs:chunk_text "The dataset is at daily grain. Video_id and channel_id are stable join keys. Avoid joining to event-level engagement without first aggregating engagement to daily grain."@en ;
                                                      docs:chunk_title "Join keys and grain"@en ;
                                                      rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 04"@en ;
                                                      dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 04 has title Join keys and grain."@en .


###  https://www.michaeldebellis.com/streamforge/Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_05
sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_05 rdf:type owl:NamedIndividual ,
                                                               docs:Document_Chunk ;
                                                      docs:chunk_index 5 ;
                                                      docs:chunk_text "We validate that delivered impressions reconcile to billed impressions within 0.5%. Outliers are investigated by country, device, and ad format."@en ;
                                                      docs:chunk_title "Validation checks"@en ;
                                                      rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 05"@en ;
                                                      dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 05 has title Validation checks."@en .


###  https://www.michaeldebellis.com/streamforge/Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_06
sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_06 rdf:type owl:NamedIndividual ,
                                                               docs:Document_Chunk ;
                                                      docs:chunk_index 6 ;
                                                      docs:chunk_text "Publish a documented 'ads_revenue_daily' view as the canonical table for reporting. Deprecate ad-hoc spreadsheets and require dashboard owners to reference the canonical view."@en ;

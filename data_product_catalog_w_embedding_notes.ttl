###  https://www.michaeldebellis.com/streamforge/Describe_User_Data_Product_SPARQL_Implementation
sf:Describe_User_Data_Product_SPARQL_Implementation rdf:type owl:NamedIndividual ,
                                                             dp:Port_Implementation ;
                                                    dp:is_implementation_for sf:Describe_User_Data_Product ;
                                                    dp:uses_technology dp:SPARQL ;
                                                    dp:has_sparql_query_text """PREFIX dp:   <https://www.michaeldebellis.com/dp/>
CONSTRUCT {
  dp:User_Data_Product ?p1 ?o .
  ?s ?p2 dp:User_Data_Product .}
WHERE {
  { dp:User_Data_Product ?p1 ?o }
  UNION
  { ?s ?p2 dp:User_Data_Product }}""" ;
                                                    dctm:contributor "Michael DeBellis" ;
                                                    dctm:created "2026-02-05T21:27:55+00:00"^^xsd:dateTime ;
                                                    rdfs:label "Describe User Data Product SPARQL Implementation"@en ;
                                                    dp:embedding_note "Describe User Data Product SPARQL Implementation has contributor Michael DeBellis."@en ,
                                                                      "Describe User Data Product SPARQL Implementation is an instance of Port Implementation."@en ,
                                                                      "Describe User Data Product SPARQL Implementation is implementation for Describe User Data Product."@en ,
                                                                      "Describe User Data Product SPARQL Implementation uses technology SPARQL."@en .



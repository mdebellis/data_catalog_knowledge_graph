dp:Implementation_Artifact rdf:type owl:Class ;
                           rdfs:subClassOf dp:Catalog_Asset ;
                           rdfs:comment "Implementation artifacts represent concrete technical resources associated with a port implementation. They are modeled as Assets so they can be cataloged, governed, referenced, and evolved independently of the conceptual Data Product and its contract." ;
                           rdfs:label "Implementation Artifact"@en ;
                           skos:definition "A tangible artifact that realizes or documents the technical implementation of a Data Product port or service, such as source code, configuration files, schemas, scripts, or supporting images."@en ;
                           dp:embedding_note "Implementation Artifact has definition A tangible artifact that realizes or documents the technical implementation of a Data Product port or service, such as source code, configuration files, schemas, scripts, or supporting images."@en .



###  https://www.michaeldebellis.com/streamforge/Creator_Growth_Metric_Computation_Run_2026_02_08
sf:Creator_Growth_Metric_Computation_Run_2026_02_08 rdf:type owl:NamedIndividual ,
                                                             dp:Data_Analysis_Activity ;
                                                    prov:generated sf:Creator_Growth_Metric_Snapshot_2026_02_08 ;
                                                    prov:used sf:SF_Creator_Insights_Dataset ;
                                                    prov:wasAssociatedWith sf:Analytics_Engineering_Team ;
                                                    dcterms:description "A scheduled analytics pipeline run that computes the executive 'Creator Growth' metric by aggregating creator KPIs from the SF Creator Insights Dataset. This activity produces the metric snapshot used in executive dashboards and strategic reporting."@en ,
                                                                        "Computation step that derives the executive 'Creator Growth' dashboard metric from the SF Creator Insights Dataset by applying the dashboard reporting window, aggregation rules, and metric definition."@en ;
                                                    rdfs:label "Creator Growth Metric Computation (2026-02-08)"@en ,
                                                               "Creator Growth Metric Computation Run (2026-02-08)"@en ;
                                                    skos:definition "An analytics computation activity that transforms aggregated creator performance indicators into the executive-level Creator Growth metric."@en ;
                                                    prov:endedAtTime "2026-02-08T07:27:00-08:00"^^xsd:dateTime ;
                                                    prov:startedAtTime "2026-02-08T07:26:00-08:00"^^xsd:dateTime ;
                                                    dp:embedding_note "Creator Growth Metric Computation (2026-02-08) generated Creator Growth Metric Snapshot (2026-02-08)."@en ,
                                                                      "Creator Growth Metric Computation (2026-02-08) used SF Creator Insights Dataset."@en ,
                                                                      "Creator Growth Metric Computation (2026-02-08) was associated with Analytics Engineering Team."@en ,
                                                                      "Creator Growth Metric Computation (2026-02-08) was generated from Analytics Engineering Team."@en ,
                                                                      "Creator Growth Metric Computation (2026-02-08) was generated from Creator Growth Metric Snapshot (2026-02-08)."@en ,
                                                                      "Creator Growth Metric Computation Run (2026-02-08) was generated from Analytics Engineering Team."@en ,
                                                                      "Creator Growth Metric Computation Run (2026-02-08) was generated from Creator Growth Metric Snapshot (2026-02-08)."@en .


###  https://www.michaeldebellis.com/streamforge/Creator_Growth_Metric_Snapshot_2026_02_08
sf:Creator_Growth_Metric_Snapshot_2026_02_08 rdf:type owl:NamedIndividual ,
                                                      prov:Entity ;
                                             prov:wasDerivedFrom sf:SF_Creator_Insights_Dataset ;
                                             prov:wasGeneratedBy sf:Creator_Growth_Metric_Computation_Run_2026_02_08 ;
                                             dcterms:description "This entity represents the specific dashboard number shown to executives for the reporting date 2026-02-08, along with the assumptions of the computation run that produced it."@en ;
                                             rdfs:label "Creator Growth Metric Snapshot (2026-02-08)"@en ;
                                             skos:definition "A point-in-time value of the 'Creator Growth' metric used in the executive dashboard. It is derived from aggregated creator KPIs in the SF Creator Insights Dataset and reflects growth trends over a defined reporting window."@en ;
                                             dp:embedding_note "Creator Growth Metric Snapshot (2026-02-08) was derived from SF Creator Insights Dataset."@en ,

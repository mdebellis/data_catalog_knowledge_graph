docs:uses_dataset rdf:type owl:ObjectProperty ;
                  rdfs:range dcat:Dataset ;
                  dcterms:description "Indicates that the document references, depends on, or was produced using a specific dataset (typically from the catalog)."@en ;
                  rdfs:label "uses dataset"@en .



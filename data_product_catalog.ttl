                   rdfs:range xsd:string ;
                   rdfs:label "has source text"@en .


###  https://www.michaeldebellis.com/dp/has_sparql_query_text
dp:has_sparql_query_text rdf:type owl:DatatypeProperty ;
                         rdfs:domain dp:Port_Implementation ;
                         rdfs:range xsd:string ;
                         rdfs:comment "Use this when a port’s behavior is defined primarily by a SPARQL query (e.g., a catalog search port or an output port implemented as a parameterized query)." ;
                         rdfs:label "has sparql query text"@en ;
                         skos:definition "A SPARQL query string that a data port executes, exposes, or uses as part of its implementation."@en .


###  https://www.michaeldebellis.com/dp/last_name
dp:last_name rdf:type owl:DatatypeProperty ;
             rdfs:domain prov:Person ;
             rdfs:range xsd:string ;
             rdfs:label "last name"@en .


###  https://www.michaeldebellis.com/dp/metric_higher_is_better
dp:metric_higher_is_better rdf:type owl:DatatypeProperty ,
                                    owl:FunctionalProperty ;

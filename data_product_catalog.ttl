dp:implemented_by_activity rdf:type owl:ObjectProperty ;
                           rdfs:comment "Data Product usage: Links a Data Product to the activity or process that implements or generates it."@en ,
                                        "Relates a Data Product Version to the PROV activity (e.g., pipeline, job, process) that produces or maintains it."@en ;
                           rdfs:label "implemented by activity"@en .


###  https://www.michaeldebellis.com/dp/implemented_by_service
dp:implemented_by_service rdf:type owl:ObjectProperty ;

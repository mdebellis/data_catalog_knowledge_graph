dp:has_quality_metric rdf:type owl:ObjectProperty ;
                      rdfs:domain dp:Data_Product ;
                      rdfs:range dp:Quality_Metric ;
                      rdfs:comment "Data Product usage: Associates a Data Product with one or more quality metrics."@en ,
                                   "Relates a Data Product Version to a quality metric describing some property of its data."@en ;
                      rdfs:label "has quality metric"@en .


